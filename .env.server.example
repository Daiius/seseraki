# worker → server 通信用の API キー
API_KEY=your-api-key

# 棋譜取得元のサイト URL とログイン Cookie
SWARS_BASE_URL=https://example.com
SWARS_SESSION_COOKIE=your-session-cookie

# CORS 許可オリジン（カンマ区切り）。同一オリジン配信が既定なので通常は未設定でよい
# （dev は Vite proxy、本番はリバプロが /api を同一オリジンで server へ渡すため CORS 不要）。
# 別オリジンの web から直接叩く特殊構成のときだけ設定する。
# CORS_ORIGINS=https://seseraki.example.com,https://other.example.com

# ログイン認証情報（平文。他の env var 同様、ファイル自体を秘密として扱う）
AUTH_USERNAME=your-username
AUTH_PASSWORD=your-password

# セッション cookie の署名鍵（ランダムな長い文字列）
SESSION_SECRET=change-me-to-a-long-random-string

# cookie 属性（本番では COOKIE_SECURE=true）。
# 現在の配信契約（web は origin 直下、API は origin 直下の /api）では COOKIE_PATH=/ 固定。
# / 以外にすると web か /api の一方に cookie が届かずログイン直後から 401 になる。
# サブパス配信（web と API を同一プレフィックス下に同居）は URL・proxy 契約と client base URL の
# 対応が別途必要で、現状は未対応。
COOKIE_SECURE=false
COOKIE_PATH=/
