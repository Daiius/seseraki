# リモート dev 公開時にだけ足す環境変数（ローカル dev では不要）。
# この例をコピーして値を埋め、compose の interpolation に食わせる:
#   cp .env.remote.example .env.remote   # .env.remote は gitignore 対象
#   docker compose --env-file .env.remote up -d --build
#
# ローカル dev（pnpm dev）はこれらを渡さず、compose 既定値で動く。リモート差分は
# すべてこのファイルに集約され、compose / vite の本体は単一のまま（override 不要）。

# https 配信（Cloudflare が TLS 終端）なので secure cookie を強制。
COOKIE_SECURE=true

# 公開ホスト名。Vite の allowedHosts と HMR(wss://<host>:443) が有効になる。
# 先頭ドットでサフィックス一括許可も可（例: .dev.example.com）。
DEV_ALLOWED_HOST=worker-dev.example.com

# web(Vite) をホストに公開するバインド。127.0.0.1 の1ポートのみに絞り、
# cloudflared をこのアドレスへ向ける（例: 127.0.0.1:8101）。
WEB_BIND=127.0.0.1:8101
