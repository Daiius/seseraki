# クライアント（ブラウザ）から見た server の URL
# 設定がある場合 vite dev は 0.0.0.0 にバインドして外部からアクセス可能になる
# 同一オリジン配信なら未設定で OK（honoClient は /api にフォールバック）
VITE_API_URL=http://localhost:4000

# swars 棋譜取得対象のユーザー ID（取得 API に渡す単一アカウント ID）
VITE_SWARS_USER_ID=YourSwarsUserId

# 自分（本人）の対局者名の候補（カンマ区切り・任意）
# 将棋アプリごとに自分の表示名が異なる場合に列挙する（例: Daiius,daiius,だいじ）。
# KIF の対局者名がいずれかに一致すれば自分とみなす（VITE_SWARS_USER_ID も自動で候補に含む）。
VITE_SELF_NAMES=
