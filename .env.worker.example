# このファイルは dev compose の worker 用テンプレート（cp .env.worker.example .env.worker）。
# SERVER_URL は compose.yml 側で http://server:4000 に固定されるため、dev では上書き不要。
# 本番 worker はこのリポジトリではなく別ディレクトリの compose + 別 .env.worker で稼働させる
# （そちらで SERVER_URL / API_KEY を本番向きにする）。dev の .env.worker を本番設定にしないこと。
#
# 注: Docker の --env-file はインラインコメントに対応していない
# (行頭の # のみコメント扱い)。値の後ろにコメントを書かないこと

ENGINE_PATH=/usr/local/bin/yaneuraou
ENGINE_DEPTH=10
# ENGINE_THREADS=1
# 本番は 2048-4096 推奨
# ENGINE_HASH=128
# ENGINE_MULTIPV=3
# ms。設定時は depth より優先
# ENGINE_BYOYOMI=5000
# 本番 NNUE 評価関数（本番イメージでは ENV で設定済み）
# ENGINE_EVAL_DIR=/usr/local/share/yaneuraou/eval
# 本番 定跡（本番イメージでは ENV で設定済み）
# ENGINE_BOOK_DIR=/usr/local/share/yaneuraou/book

SERVER_URL=http://server:4000
API_KEY=your-api-key
USE_MOCK=false
POLL_INTERVAL_MS=10000
